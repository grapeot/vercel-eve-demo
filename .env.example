# 默认 mock 模式不需要任何 credential。
EVE_DEMO_MODE=mock
SEARCH_BACKEND=mock

# live 模式必须显式开启，不能只因为环境里存在 key 就自动生效。
ALLOW_LIVE_API=0
EVE_MODEL=openai/gpt-5.4-mini
RESEARCH_BUDGET_USD=2
RESEARCH_MAX_SEARCHES=10

# Tavily：只在 SEARCH_BACKEND=tavily 时读取。
TAVILY_API_KEY=replace-with-your-real-key
TAVILY_PROJECT=replace-with-your-project-id

# Production route auth。placeholder 表示生产环境默认拒绝浏览器请求。
EVE_AUTH_MODE=placeholder
EVE_AUTH_USERNAME=replace-with-your-username
EVE_AUTH_PASSWORD=replace-with-your-password

# Owner-only Workbench persistence and security. Generate local access values with
# `npm run init:private-access`; provision Turso with `npm run init:turso`.
ACCESS_ALLOWED_CIDRS=127.0.0.1/32,::1/128
ACCESS_CHALLENGE_SECRET=replace-with-32-random-bytes-base64url
ACCESS_COOKIE_SIGNING_KEY=replace-with-32-random-bytes-base64url
CREDENTIAL_ENCRYPTION_KEY=replace-with-32-random-bytes-base64url
TURSO_DATABASE_URL=libsql://replace-with-database-hostname
TURSO_AUTH_TOKEN=replace-with-database-auth-token

# Explicit kill switch for the unsupported owner-only Codex compatibility path.
CODEX_EXPERIMENT_ENABLED=0
CODEX_MODEL=gpt-5.6-sol
