{
  "name": "vercel-eve-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Reference implementation for an owner-only Eve research workbench with inspectable Markdown artifacts",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "dev:eve": "eve dev",
    "build:eve": "eve build",
    "build": "npm run build:eve && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "RUN_LIVE_TESTS=1 node --env-file=.env.local --import tsx scripts/smoke-tavily.ts",
    "test:eve": "node --import tsx scripts/smoke-eve.mjs",
    "test:web": "node scripts/smoke-web.mjs",
    "bundle": "node scripts/build-skill-bundle.mjs",
    "benchmark:search": "node scripts/benchmark-web-search.mjs",
    "init:private-access": "node scripts/init-private-access.mjs",
    "init:turso": "node scripts/init-turso.mjs",
    "enable:codex-experiment": "node scripts/enable-codex-experiment.mjs",
    "configure:tavily": "node scripts/configure-tavily.mjs",
    "db:migrate": "node --env-file=.env.local --import tsx scripts/migrate-database.ts",
    "teardown": "node --env-file=.env.local --import tsx scripts/teardown.ts",
    "check:public": "node scripts/check-public-content.mjs",
    "verify": "npm run bundle && npm run lint && npm run typecheck && npm run test && npm run build && npm run check:public"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.84",
    "@libsql/client": "^0.17.4",
    "ai": "7.0.26",
    "eve": "0.24.4",
    "ipaddr.js": "^2.4.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.6",
    "microsandbox": "^0.5.10",
    "tsx": "^4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
